# ============================================
# AI Wallet Assistant - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# OpenAI API Key (required for AI features)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Backend
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Etherscan API Key (optional - for contract verification lookups)
ETHERSCAN_API_KEY=your-etherscan-api-key

# WalletConnect Project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# RPC URLs (optional - defaults to public endpoints)
NEXT_PUBLIC_ETHEREUM_RPC=https://eth-mainnet.g.alchemy.com/v2/your-key
NEXT_PUBLIC_POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/your-key
NEXT_PUBLIC_ARBITRUM_RPC=https://arb-mainnet.g.alchemy.com/v2/your-key
